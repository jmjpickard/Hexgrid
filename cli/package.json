{
  "name": "@jackpickard/hexgrid-cli",
  "version": "0.0.2",
  "description": "HexGrid command line client for login and repo session lifecycle",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/hexgrid.mjs",
    "README.md"
  ],
  "keywords": [
    "hexgrid",
    "cli",
    "agents",
    "codex",
    "claude",
    "mcp"
  ],
  "scripts": {
    "check": "node ./bin/hexgrid.mjs --help",
    "prepublishOnly": "npm run check"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "hexgrid": "bin/hexgrid.mjs"
  }
}
